# ============================================================
# AUTO-RFP AGENT - CONFIGURAÇÃO DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env real!
# ============================================================

# ============================================================
# BANCO DE DADOS (PostgreSQL)
# ============================================================
POSTGRES_USER=autorfppguser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=autorfpdb
POSTGRES_PORT=5432

# URL completa para SQLAlchemy (descomente e ajuste se necessário)
# DATABASE_URL=postgresql+asyncpg://autorfppguser:change_me@localhost:5432/autorfpdb

# ============================================================
# REDIS (Cache e Message Broker)
# ============================================================
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ============================================================
# API (FastAPI)
# ============================================================
API_PORT=8000
# IMPORTANTE: Gere uma chave segura em produção (min 32 caracteres)
# Use: openssl rand -hex 32
SECRET_KEY=change-this-in-production-min-32-chars
ENVIRONMENT=development
# Opções: development, staging, production

# ============================================================
# FRONTEND (Next.js)
# ============================================================
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ============================================================
# CELERY (Background Tasks)
# ============================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================
# MONITORING (Flower)
# ============================================================
FLOWER_PORT=5555

# ============================================================
# PROVEDORES DE IA
# ============================================================

# --- Opção 1: OLLAMA (Recomendado - 100% Local e Gratuito) ---
# Instale: https://ollama.com/download
# Execute: ollama pull llama3.1
# Execute: ollama pull nomic-embed-text
DEFAULT_AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Opção 2: OpenAI (requer API key e créditos) ---
# Obtenha em: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here
# DEFAULT_AI_PROVIDER=openai

# --- Opção 3: Groq (rápido, tier gratuito disponível) ---
# Obtenha em: https://console.groq.com/keys
# GROQ_API_KEY=gsk-your-groq-key-here
# DEFAULT_AI_PROVIDER=groq

# --- Opção 4: Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# DEFAULT_AI_PROVIDER=anthropic

# ============================================================
# JWT (JSON Web Tokens)
# ============================================================
# Use a mesma SECRET_KEY ou defina uma separada
JWT_SECRET=change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# UPLOAD E ARQUIVOS
# ============================================================
# Caminho base para uploads (relativo à raiz do projeto)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600
# 100MB em bytes

# ============================================================
# LOGGING
# ============================================================
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Arquivo de log (opcional, deixe vazio para stdout apenas)
# LOG_FILE=logs/app.log

# ============================================================
# FEATURE FLAGS (opcional)
# ============================================================
# ENABLE_ANALYTICS=false
# ENABLE_RATE_LIMITING=true
